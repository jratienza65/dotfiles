## Navigation (lalt - ...)
# Space Navigation (four spaces per display): lalt - {1, 2, 3, 4}
lalt - 1 : SPACES=($(yabai -m query --displays --display | jq '.spaces[]')) && [[ -n $SPACES[1] ]] && yabai -m space --focus $SPACES[1]
lalt - 2 : SPACES=($(yabai -m query --displays --display | jq '.spaces[]')) && [[ -n $SPACES[2] ]] && yabai -m space --focus $SPACES[2]
lalt - 3 : SPACES=($(yabai -m query --displays --display | jq '.spaces[]')) && [[ -n $SPACES[3] ]] && yabai -m space --focus $SPACES[3]
lalt - 4 : SPACES=($(yabai -m query --displays --display | jq '.spaces[]')) && [[ -n $SPACES[4] ]] && yabai -m space --focus $SPACES[4]
lalt - 5 : SPACES=($(yabai -m query --displays --display | jq '.spaces[]')) && [[ -n $SPACES[5] ]] && yabai -m space --focus $SPACES[5]
lalt - 6 : SPACES=($(yabai -m query --displays --display | jq '.spaces[]')) && [[ -n $SPACES[6] ]] && yabai -m space --focus $SPACES[6]

# Cycle spaces, Hyprland-style, scales to ANY number of spaces: cmd + ctrl - {left, right}
# cmd-based so it is never delivered to terminal/TUI apps (nvim, zellij, lazygit, claude) even over SSH;
# the extra ctrl avoids the bare cmd+arrow GUI shortcuts (browser back/forward, line start/end).
# The "|| --focus first/last" gives wraparound cycling.
cmd + ctrl - left  : yabai -m space --focus prev || yabai -m space --focus last
cmd + ctrl - right : yabai -m space --focus next || yabai -m space --focus first

# Window Navigation (through display borders): lalt - {j, k, l, ö}
lalt - j    : yabai -m window --focus west  || yabai -m display --focus west
lalt - k    : yabai -m window --focus south || yabai -m display --focus south
lalt - l    : yabai -m window --focus north || yabai -m display --focus north
lalt - 0x29 : yabai -m window --focus east  || yabai -m display --focus east

# Extended Window Navigation: lalt - {h, ä}
lalt -    h : yabai -m window --focus first
lalt - 0x27 : yabai -m window --focus  last

# Float / Unfloat window: lalt - space
lalt - space : yabai -m window --toggle float

# Make window zoom to fullscreen: lshift + lalt - f
lshift + lalt - f : yabai -m window --toggle zoom-fullscreen

# Make window zoom to parent node: lalt - f
lalt - f : yabai -m window --toggle zoom-parent

## Window Movement (lshift + lalt - ...)
# Moving windows in spaces: lshift + lalt - {j, k, l, ö}
lshift + lalt - j : yabai -m window --warp west || $(yabai -m window --display west && yabai -m display --focus west && yabai -m window --warp last) || yabai -m window --move rel:-10:0
lshift + lalt - k : yabai -m window --warp south || $(yabai -m window --display south && yabai -m display --focus south) || yabai -m window --move rel:0:10
lshift + lalt - l : yabai -m window --warp north || $(yabai -m window --display north && yabai -m display --focus north) || yabai -m window --move rel:0:-10
lshift + lalt - 0x29 : yabai -m window --warp east || $(yabai -m window --display east && yabai -m display --focus east && yabai -m window --warp first) || yabai -m window --move rel:10:0

# Toggle split orientation of the selected windows node: lshift + lalt - s
lshift + lalt - s : yabai -m window --toggle split

# Moving windows between spaces: lshift + lalt - {1, 2, 3, 4, p, n } (Assumes 4 Spaces Max per Display)
lshift + lalt - 1 : SPACES=($(yabai -m query --displays --display | jq '.spaces[]')) && [[ -n $SPACES[1] ]] \
                  && yabai -m window --space $SPACES[1]

lshift + lalt - 2 : SPACES=($(yabai -m query --displays --display | jq '.spaces[]')) && [[ -n $SPACES[2] ]] \
                  && yabai -m window --space $SPACES[2]

lshift + lalt - 3 : SPACES=($(yabai -m query --displays --display | jq '.spaces[]')) && [[ -n $SPACES[3] ]] \
                  && yabai -m window --space $SPACES[3]

lshift + lalt - 4 : SPACES=($(yabai -m query --displays --display | jq '.spaces[]')) && [[ -n $SPACES[4] ]] \
                  && yabai -m window --space $SPACES[4]

lshift + lalt - 5 : SPACES=($(yabai -m query --displays --display | jq '.spaces[]')) && [[ -n $SPACES[5] ]] \
                  && yabai -m window --space $SPACES[5]

lshift + lalt - 6 : SPACES=($(yabai -m query --displays --display | jq '.spaces[]')) && [[ -n $SPACES[6] ]] \
                  && yabai -m window --space $SPACES[6]

lshift + lalt - p : yabai -m window --space prev && yabai -m space --focus prev
lshift + lalt - n : yabai -m window --space next && yabai -m space --focus next

# Hyprland-style: move focused window to prev/next space and follow it: shift + cmd + ctrl - {left, right}
shift + cmd + ctrl - left  : yabai -m window --space prev && yabai -m space --focus prev
shift + cmd + ctrl - right : yabai -m window --space next && yabai -m space --focus next

# Create / destroy spaces on the fly (needed to actually reach 6-8+ spaces): cmd + ctrl - {n, backspace}
cmd + ctrl - n         : yabai -m space --create  && yabai -m space --focus last
cmd + ctrl - 0x33      : yabai -m space --destroy

# Mirror Space on X and Y Axis: lshift + lalt - {x, y}
lshift + lalt - x : yabai -m space --mirror x-axis
lshift + lalt - y : yabai -m space --mirror y-axis

## Stacks (lshift + ctrl - ...)
# Add the active window to the window or stack to the {direction}: lshift + ctrl - {j, k, l, ö}
lshift + ctrl - j    : yabai -m window  west --stack $(yabai -m query --windows --window | jq -r '.id')
lshift + ctrl - k    : yabai -m window south --stack $(yabai -m query --windows --window | jq -r '.id')
lshift + ctrl - l    : yabai -m window north --stack $(yabai -m query --windows --window | jq -r '.id')
lshift + ctrl - 0x29 : yabai -m window  east --stack $(yabai -m query --windows --window | jq -r '.id')

# Stack Navigation: lshift + ctrl - {n, p}
lshift + ctrl - n : yabai -m window --focus stack.next
lshift + ctrl - p : yabai -m window --focus stack.prev

## Resize (ctrl + lalt - ...)
# Resize windows: ctrl + lalt - {j, k, l, ö}
ctrl + lalt - j    : yabai -m window --resize right:-100:0 || yabai -m window --resize left:-100:0
ctrl + lalt - k    : yabai -m window --resize bottom:0:100 || yabai -m window --resize top:0:100
ctrl + lalt - l    : yabai -m window --resize bottom:0:-100 || yabai -m window --resize top:0:-100
ctrl + lalt - 0x29 : yabai -m window --resize right:100:0 || yabai -m window --resize left:100:0

# Equalize size of windows: ctrl + lalt - e
ctrl + lalt - e : yabai -m space --balance

# Enable / Disable gaps in current workspace: ctrl + lalt - g
ctrl + lalt - g : yabai -m space --toggle padding; yabai -m space --toggle gap

## Insertion (lshift + ctrl + lalt - ...)
# Set insertion point for focused container: lshift + ctrl + lalt - {j, k, l, ö, s}
lshift + ctrl + lalt - j : yabai -m window --insert west
lshift + ctrl + lalt - k : yabai -m window --insert south
lshift + ctrl + lalt - l : yabai -m window --insert north
lshift + ctrl + lalt - 0x29 : yabai -m window --insert east
lshift + ctrl + lalt - s : yabai -m window --insert stack

# New window in hor./ vert. splits for all applications with yabai
lalt - s : yabai -m window --insert east;  skhd -k "cmd - n"
lalt - v : yabai -m window --insert south; skhd -k "cmd - n"

# Toggle sketchybar
lshift + lalt - space : sketchybar --bar hidden=toggle
